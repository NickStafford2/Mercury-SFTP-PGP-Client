# SFTP server hostname provided by Mercury.
# Production example: SFTP_HOST=sftp.partner.example.com
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USER=username

# SSH private key created from docs/SSHInstructions.md.
# Production example: SSH_KEY_PATH=/etc/mercury/sftp/mercury_sftp_ed25519
SSH_KEY_PATH=~/.ssh/mercury_sftp_ed25519

# Remote folders provided by Mercury.
# Production example: REMOTE_INBOUND_DIR=/from_mercury
# Production example: REMOTE_OUTBOUND_DIR=/to_mercury
REMOTE_INBOUND_DIR=/inbound
REMOTE_OUTBOUND_DIR=/outbound

# Verified Mercury PGP fingerprint after importing their public key.
# Production example: PGP_RECIPIENT=ABCD1234EF567890ABCD1234EF567890ABCD1234
PGP_RECIPIENT=

# Passphrase for our local GPG secret key, if needed for decryption.
PGP_PASSPHRASE=

# Local working directory for encrypted files before/after transfer.
WORK_DIR=work
