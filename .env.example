# SFTP server hostname. Production is usually a partner-provided DNS name.
# Production example: SFTP_HOST=sftp.partner.example.com
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USER=username

# SSH private key used for SFTP authentication. Ed25519 is the modern default.
# Production example: SSH_KEY_PATH=/etc/mercury/sftp/id_ed25519
SSH_KEY_PATH=~/.ssh/id_ed25519
SSH_KEY_PASSPHRASE=
SFTP_TIMEOUT_SECONDS=30

# Remote folders provided by the SFTP server/partner.
# Production example: REMOTE_INBOUND_DIR=/from_partner
# Production example: REMOTE_OUTBOUND_DIR=/to_partner
REMOTE_INBOUND_DIR=/inbound
REMOTE_OUTBOUND_DIR=/outbound

# GPG recipient to encrypt outbound files for. Prefer a verified fingerprint.
# Production example: PGP_RECIPIENT=ABCD1234EF567890ABCD1234EF567890ABCD1234
PGP_RECIPIENT=

# Optional public key file for file-based recipient encryption.
# Production example: PGP_PUBLIC_KEY_PATH=/etc/mercury/pgp/partner-public.asc
PGP_PUBLIC_KEY_PATH=keys/public.asc

# Passphrase for the local secret key used by gpg during decryption.
PGP_PASSPHRASE=secret

# Optional isolated GPG home/keyring.
# Production example: GPG_HOME=/etc/mercury/gnupg
GPG_HOME=

# Local working directory for encrypted downloads/uploads before transfer.
WORK_DIR=work
